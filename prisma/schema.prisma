generator client {
  provider = "prisma-client-js"
}

ddatasource db {
  provider = "postgresql"
  postgresql://neondb_owner:npg_LWeTGU0Evtu8@ep-frosty-dew-anzf5nyq-pooler.c-6.us-east-1.aws.neon.tech/neondb?sslmode=require
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  password      String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  role          Role           @default(STUDENT)
  borrowRecords BorrowRecord[]
}

model Book {
  id            String         @id @default(cuid())
  title         String
  author        String
  description   String?
  category      String
  isAvailable   Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  borrowRecords BorrowRecord[]
}

model BorrowRecord {
  id         String    @id @default(cuid())
  userId     String
  bookId     String
  borrowDate DateTime  @default(now())
  dueDate    DateTime
  returnDate DateTime?
  status     String    @default("PENDING")
  book       Book      @relation(fields: [bookId], references: [id])
  user       User      @relation(fields: [userId], references: [id])
}

enum Role {
  STUDENT
  LIBRARIAN
}
